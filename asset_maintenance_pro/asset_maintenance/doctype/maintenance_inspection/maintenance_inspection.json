{
 "doctype": "DocType",
 "name": "Maintenance Inspection",
 "module": "Asset Maintenance",
 "naming_rule": "By Naming Series",
 "autoname": "naming_series:",
 "title_field": "inspection_type",
 "track_changes": 1,
 "engine": "InnoDB",
 "field_order": [
  "naming_series","inspection_type","branch","location","asset",
  "column_break_1","status","inspection_date","next_due_date","inspector",
  "section_items","items",
  "section_result","overall_result","passed_count","failed_count","critical_failures",
  "column_break_result","findings","corrective_action_required","corrective_action_deadline",
  "section_compliance","certificate_no","certificate_expiry","authority","attachment",
  "section_sign","inspected_by","signed_off_by","signed_off_on"
 ],
 "fields": [
  {"fieldname":"naming_series","fieldtype":"Select","label":"Series","options":"INS-.YYYY.-.#####"},
  {"fieldname":"inspection_type","fieldtype":"Select","label":"Inspection Type","reqd":1,"in_list_view":1,
   "options":"Fire Suppression\nGas System\nHood Cleaning\nTemperature Log\nElectrical\nPest Control\nGeneral Safety\nEquipment Audit"},
  {"fieldname":"branch","fieldtype":"Link","label":"Branch","options":"Branch","reqd":1,"in_list_view":1,"in_standard_filter":1},
  {"fieldname":"location","fieldtype":"Link","label":"Location","options":"Maintenance Location"},
  {"fieldname":"asset","fieldtype":"Link","label":"Asset","options":"Asset"},
  {"fieldname":"column_break_1","fieldtype":"Column Break","label":""},
  {"fieldname":"status","fieldtype":"Select","label":"Status","in_list_view":1,
   "options":"Scheduled\nIn Progress\nPassed\nFailed\nCancelled","default":"Scheduled"},
  {"fieldname":"inspection_date","fieldtype":"Date","label":"Date","reqd":1,"default":"Today"},
  {"fieldname":"next_due_date","fieldtype":"Date","label":"Next Due Date"},
  {"fieldname":"inspector","fieldtype":"Link","label":"Inspector","options":"User"},
  {"fieldname":"section_items","fieldtype":"Section Break","label":"Inspection Checklist"},
  {"fieldname":"items","fieldtype":"Table","label":"Checkpoints","options":"Inspection Item"},
  {"fieldname":"section_result","fieldtype":"Section Break","label":"Result Summary"},
  {"fieldname":"overall_result","fieldtype":"Select","label":"Overall Result",
   "options":"\nPass\nFail\nConditional Pass","in_list_view":1},
  {"fieldname":"passed_count","fieldtype":"Int","label":"Passed","read_only":1},
  {"fieldname":"failed_count","fieldtype":"Int","label":"Failed","read_only":1},
  {"fieldname":"critical_failures","fieldtype":"Int","label":"Critical Failures","read_only":1},
  {"fieldname":"column_break_result","fieldtype":"Column Break","label":""},
  {"fieldname":"findings","fieldtype":"Text Editor","label":"Key Findings"},
  {"fieldname":"corrective_action_required","fieldtype":"Check","label":"Corrective Action Required","default":"0"},
  {"fieldname":"corrective_action_deadline","fieldtype":"Date","label":"Action Deadline",
   "depends_on":"eval:doc.corrective_action_required==1"},
  {"fieldname":"section_compliance","fieldtype":"Section Break","label":"Certificate & Compliance"},
  {"fieldname":"certificate_no","fieldtype":"Data","label":"Certificate No."},
  {"fieldname":"certificate_expiry","fieldtype":"Date","label":"Certificate Expiry"},
  {"fieldname":"authority","fieldtype":"Data","label":"Issuing Authority"},
  {"fieldname":"attachment","fieldtype":"Attach","label":"Report/Certificate"},
  {"fieldname":"section_sign","fieldtype":"Section Break","label":"Sign-off"},
  {"fieldname":"inspected_by","fieldtype":"Link","label":"Inspected By","options":"User","default":"__user","read_only":1},
  {"fieldname":"signed_off_by","fieldtype":"Link","label":"Signed Off By","options":"User"},
  {"fieldname":"signed_off_on","fieldtype":"Datetime","label":"Signed Off On","read_only":1}
 ],
 "permissions": [
  {"role":"System Manager","read":1,"write":1,"create":1,"delete":1},
  {"role":"Branch Manager","read":1,"write":1,"create":1,"delete":0},
  {"role":"Maintenance Technician","read":1,"write":1,"create":1,"delete":0}
 ],
 "states": [
  {"color":"Blue","title":"Scheduled"},{"color":"Yellow","title":"In Progress"},
  {"color":"Green","title":"Passed"},{"color":"Red","title":"Failed"},{"color":"Gray","title":"Cancelled"}
 ],
 "sort_field":"inspection_date","sort_order":"DESC"
}
