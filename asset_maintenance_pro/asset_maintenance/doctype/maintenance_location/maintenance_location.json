  {"fieldname":"area_type","fieldtype":"Select","label":"Area Type",
   "options":"\nKitchen\nStorage\nDining Hall\nRooftop\nElectrical Room\nCold Room\nOffice\nExternal"},
  {"fieldname":"notes","fieldtype":"Small Text","label":"Notes"}
 ],
 "permissions": [
  {"role":"System Manager","read":1,"write":1,"create":1,"delete":1},
  {"role":"Branch Manager","read":1,"write":0,"create":0,"delete":0},
  {"role":"Maintenance Technician","read":1,"write":0,"create":0,"delete":0}
 ],
 "sort_field":"location_name","sort_order":"ASC","states":[]
