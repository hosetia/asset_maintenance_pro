{
 "doctype": "DocType",
 "name": "Maintenance Work Order",
 "module": "Asset Maintenance",
 "naming_rule": "By Naming Series",
 "autoname": "naming_series:",
 "title_field": "name",
 "search_fields": "maintenance_request,asset,branch,status,assigned_team",
 "track_changes": 1,
 "engine": "InnoDB",
 "field_order": [
  "naming_series","maintenance_request","asset","branch","location",
  "column_break_1","status","kanban_column","priority","work_order_type",
  "section_assignment","assigned_team","lead_technician","scheduled_start","scheduled_end",
  "column_break_assign","actual_start","actual_end","total_hours","downtime_hours",
  "section_diagnosis","symptom_code","cause_code","failure_class","remedy_code",
  "column_break_diag","root_cause_analysis","corrective_actions",
  "section_tasks","tasks","section_time","time_logs",
  "section_completion","total_labor_cost","total_parts_cost","total_cost",
  "completion_notes","completion_photos","is_food_safety_impact","is_closure_risk",
  "section_verification","verified_by","verified_on","verification_notes",
  "section_vendor","is_vendor_job","vendor","vendor_po","vendor_response_time","vendor_invoice"
 ],
 "fields": [
  {"fieldname":"naming_series","fieldtype":"Select","label":"Series","options":"WO-.YYYY.-.#####","reqd":1},
  {"fieldname":"maintenance_request","fieldtype":"Link","label":"Maintenance Request","options":"Maintenance Request","in_list_view":1,"in_standard_filter":1,"search_index":1},
  {"fieldname":"asset","fieldtype":"Link","label":"Asset","options":"Asset","in_list_view":1,"in_standard_filter":1},
  {"fieldname":"branch","fieldtype":"Link","label":"Branch","options":"Branch","in_list_view":1,"in_standard_filter":1,"search_index":1},
  {"fieldname":"location","fieldtype":"Link","label":"Location","options":"Maintenance Location"},
  {"fieldname":"column_break_1","fieldtype":"Column Break","label":""},
  {"fieldname":"status","fieldtype":"Select","label":"Status","in_list_view":1,"in_standard_filter":1,
   "options":"Draft\nReady\nScheduled Today\nOn Route\nOn Site\nRepairing\nTesting\nCompleted\nManager Verification\nClosed\nCancelled",
   "default":"Draft","reqd":1,"search_index":1},
  {"fieldname":"kanban_column","fieldtype":"Select","label":"Kanban Column","hidden":1,
   "options":"Ready\nScheduled Today\nOn Route\nOn Site\nRepairing\nTesting\nCompleted\nManager Verification"},
  {"fieldname":"priority","fieldtype":"Select","label":"Priority","options":"Low\nMedium\nHigh\nCritical","default":"Medium","in_list_view":1},
  {"fieldname":"work_order_type","fieldtype":"Select","label":"Type",
   "options":"Corrective\nPreventive\nInspection\nVendor\nEmergency","in_list_view":1},
  {"fieldname":"section_assignment","fieldtype":"Section Break","label":"Assignment & Schedule"},
  {"fieldname":"assigned_team","fieldtype":"Link","label":"Team","options":"Maintenance Team","in_standard_filter":1},
  {"fieldname":"lead_technician","fieldtype":"Link","label":"Lead Technician","options":"User"},
  {"fieldname":"scheduled_start","fieldtype":"Datetime","label":"Scheduled Start"},
  {"fieldname":"scheduled_end","fieldtype":"Datetime","label":"Scheduled End"},
  {"fieldname":"column_break_assign","fieldtype":"Column Break","label":""},
  {"fieldname":"actual_start","fieldtype":"Datetime","label":"Actual Start"},
  {"fieldname":"actual_end","fieldtype":"Datetime","label":"Actual End"},
  {"fieldname":"total_hours","fieldtype":"Float","label":"Total Hours","read_only":1},
  {"fieldname":"downtime_hours","fieldtype":"Float","label":"Downtime Hours"},
  {"fieldname":"section_diagnosis","fieldtype":"Section Break","label":"Diagnosis & Root Cause"},
  {"fieldname":"symptom_code","fieldtype":"Link","label":"Symptom","options":"Asset Taxonomy"},
  {"fieldname":"cause_code","fieldtype":"Link","label":"Cause","options":"Asset Taxonomy"},
  {"fieldname":"failure_class","fieldtype":"Select","label":"Failure Class",
   "options":"\nElectrical\nMechanical\nOperational\nCleaning\nExternal\nAge/Wear\nMisuse"},
  {"fieldname":"remedy_code","fieldtype":"Link","label":"Remedy","options":"Asset Taxonomy"},
  {"fieldname":"column_break_diag","fieldtype":"Column Break","label":""},
  {"fieldname":"root_cause_analysis","fieldtype":"Text Editor","label":"Root Cause Analysis"},
  {"fieldname":"corrective_actions","fieldtype":"Text Editor","label":"Corrective Actions"},
  {"fieldname":"section_tasks","fieldtype":"Section Break","label":"Tasks & Checklist"},
  {"fieldname":"tasks","fieldtype":"Table","label":"Tasks","options":"Work Order Task"},
  {"fieldname":"section_time","fieldtype":"Section Break","label":"Time Logs"},
  {"fieldname":"time_logs","fieldtype":"Table","label":"Time Logs","options":"Work Order Time Log"},
  {"fieldname":"section_completion","fieldtype":"Section Break","label":"Completion"},
  {"fieldname":"total_labor_cost","fieldtype":"Currency","label":"Labor Cost","read_only":1},
  {"fieldname":"total_parts_cost","fieldtype":"Currency","label":"Parts Cost","read_only":1},
  {"fieldname":"total_cost","fieldtype":"Currency","label":"Total Cost","read_only":1},
  {"fieldname":"completion_notes","fieldtype":"Text Editor","label":"Completion Notes"},
  {"fieldname":"completion_photos","fieldtype":"Attach Image","label":"Completion Photo"},
  {"fieldname":"is_food_safety_impact","fieldtype":"Check","label":"Food Safety Impact","default":"0"},
  {"fieldname":"is_closure_risk","fieldtype":"Check","label":"Closure Risk","default":"0"},
  {"fieldname":"section_verification","fieldtype":"Section Break","label":"Manager Verification","collapsible":1},
  {"fieldname":"verified_by","fieldtype":"Link","label":"Verified By","options":"User","read_only":1},
  {"fieldname":"verified_on","fieldtype":"Datetime","label":"Verified On","read_only":1},
  {"fieldname":"verification_notes","fieldtype":"Small Text","label":"Verification Notes"},
  {"fieldname":"section_vendor","fieldtype":"Section Break","label":"Vendor Job","collapsible":1},
  {"fieldname":"is_vendor_job","fieldtype":"Check","label":"Vendor Job","default":"0"},
  {"fieldname":"vendor","fieldtype":"Link","label":"Vendor","options":"Supplier","depends_on":"eval:doc.is_vendor_job==1"},
  {"fieldname":"vendor_po","fieldtype":"Link","label":"Purchase Order","options":"Purchase Order","depends_on":"eval:doc.is_vendor_job==1"},
  {"fieldname":"vendor_response_time","fieldtype":"Float","label":"Vendor Response (hrs)","depends_on":"eval:doc.is_vendor_job==1"},
  {"fieldname":"vendor_invoice","fieldtype":"Link","label":"Purchase Invoice","options":"Purchase Invoice","depends_on":"eval:doc.is_vendor_job==1"}
 ],
 "permissions": [
  {"role":"System Manager","read":1,"write":1,"create":1,"delete":1,"email":1,"print":1},
  {"role":"Branch Manager","read":1,"write":1,"create":0,"delete":0,"email":1,"print":1},
  {"role":"Maintenance Technician","read":1,"write":1,"create":0,"delete":0,"print":1}
 ],
 "states": [
  {"color":"Gray","title":"Draft"},{"color":"Blue","title":"Ready"},
  {"color":"Blue","title":"Scheduled Today"},{"color":"Orange","title":"On Route"},
  {"color":"Yellow","title":"On Site"},{"color":"Yellow","title":"Repairing"},
  {"color":"Purple","title":"Testing"},{"color":"Green","title":"Completed"},
  {"color":"Purple","title":"Manager Verification"},{"color":"Green","title":"Closed"},
  {"color":"Red","title":"Cancelled"}
 ],
 "sort_field":"modified","sort_order":"DESC"
}
